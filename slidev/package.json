{
  "name": "spring-batch-demo-slidev",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:all",
    "build:onion": "slidev build deck-onion.md --out dist-onion",
    "build:phase1": "slidev build deck-phase1.md --out dist-phase1",
    "build:phase2": "slidev build deck-phase2.md --out dist-phase2",
    "build:phase3": "slidev build deck-phase3.md --out dist-phase3",
    "build:overall": "slidev build deck-overall-flows.md --out dist-overall-flows",
    "build:all": "npm run build:onion && npm run build:phase1 && npm run build:phase2 && npm run build:phase3 && npm run build:overall",
    "dev:onion": "slidev deck-onion.md",
    "dev:phase1": "slidev deck-phase1.md",
    "dev:phase2": "slidev deck-phase2.md",
    "dev:phase3": "slidev deck-phase3.md",
    "dev:overall": "slidev deck-overall-flows.md",
    "legacy:dev": "slidev slides.md",
    "legacy:dev:phase2": "slidev slides-phase2.md",
    "legacy:dev:phase2-flows": "slidev slides-phase2-flows.md",
    "legacy:dev:flows": "slidev flows.md",
    "legacy:dev:phase3": "slidev slides-phase3.md"
  },
  "devDependencies": {
    "@slidev/cli": "52.14.2",
    "@slidev/theme-default": "0.25.0"
  }
}
